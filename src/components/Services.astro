---
const services = [
  {
    title: "S.R.C",
    subtitle: "Sistema de Reserva",
    description: "Plataforma digital de reservas de carga con confirmacion automatica y seguimiento en tiempo real.",
    icon: "monitor",
    accent: "blue",
    featured: false,
  },
  {
    title: "Transporte Maritimo",
    subtitle: "Carga internacional",
    description: "Embarques FCL y LCL a los principales puertos del mundo con las mejores navieras.",
    icon: "ship",
    accent: "cyan",
    featured: true,
  },
  {
    title: "Transporte Terrestre",
    subtitle: "Logistica nacional",
    description: "Retiro y despacho de contenedores en todo Chile, coordinado con nuestras operaciones maritimas.",
    icon: "truck",
    accent: "red",
    featured: false,
  },
  {
    title: "Cargas Especializadas",
    subtitle: "Refrigerado y congelado",
    description: "Manejo experto de frutas, productos del mar, carnes y todo tipo de carga temperatura controlada.",
    icon: "snowflake",
    accent: "cyan",
    featured: false,
  },
];

const icons: Record<string, string> = {
  monitor: '<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>',
  ship: '<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M2 20a5 5 0 0 0 5-1 5 5 0 0 0 5 1 5 5 0 0 0 5-1 5 5 0 0 0 5 1"/><path d="M19 17V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v10"/><path d="M12 2v3"/></svg>',
  truck: '<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>',
  snowflake: '<svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2v20M17 7l-5 5-5-5M7 17l5-5 5 5M2 12h20M7 7l-2-2M17 7l2-2M7 17l-2 2M17 17l2 2"/></svg>',
};

const accentColors: Record<string, { bg: string; text: string; iconBg: string }> = {
  blue: { bg: "bg-blue/5", text: "text-blue", iconBg: "bg-gradient-to-br from-blue/20 to-blue/5" },
  cyan: { bg: "bg-cyan/5", text: "text-cyan", iconBg: "bg-gradient-to-br from-cyan/20 to-cyan/5" },
  red: { bg: "bg-red/5", text: "text-red", iconBg: "bg-gradient-to-br from-red/20 to-red/5" },
};
---

<section id="servicios" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-14 lg:mb-20">
      <div class="reveal inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue/5 border border-blue/10 mb-6">
        <span class="w-2 h-2 bg-blue rounded-full"></span>
        <span class="text-sm text-blue font-[family-name:var(--font-inter)] font-medium">Nuestros Servicios</span>
      </div>
      <h2 class="reveal text-[26px] lg:text-[36px] font-bold text-navy font-[family-name:var(--font-inter)] leading-tight mb-4">
        Todo lo que necesitas para<br class="hidden sm:block" /> exportar e importar
      </h2>
      <p class="reveal text-base text-gray-500 font-[family-name:var(--font-poppins)] max-w-2xl mx-auto">
        Soluciones integrales de logistica naviera con tecnologia de punta y atencion personalizada.
      </p>
    </div>

    <!-- Desktop Grid -->
    <div class="hidden lg:grid lg:grid-cols-2 gap-5">
      {services.map((service) => (
        <div
          class:list={[
            "reveal group rounded-2xl p-7 transition-all duration-300 hover:shadow-xl",
            service.featured
              ? "bg-navy text-white hover:shadow-navy/20"
              : "bg-gray-50 hover:bg-white border border-gray-100 hover:border-gray-200 hover:shadow-gray-200/50",
          ]}
        >
          <div
            class:list={[
              "w-13 h-13 rounded-xl flex items-center justify-center mb-5",
              service.featured
                ? "bg-white/10"
                : accentColors[service.accent].iconBg,
            ]}
          >
            <span
              class:list={[
                service.featured ? "text-cyan" : accentColors[service.accent].text,
              ]}
              set:html={icons[service.icon]}
            />
          </div>
          <h3
            class:list={[
              "text-lg font-semibold font-[family-name:var(--font-inter)] mb-1",
              service.featured ? "text-white" : "text-navy",
            ]}
          >
            {service.title}
          </h3>
          <p
            class:list={[
              "text-sm mb-3",
              service.featured ? "text-cyan/80" : accentColors[service.accent].text + "/80",
            ]}
          >
            {service.subtitle}
          </p>
          <p
            class:list={[
              "text-sm leading-relaxed mb-5",
              service.featured ? "text-white/70" : "text-gray-500",
            ]}
          >
            {service.description}
          </p>
          <a
            href="#"
            class:list={[
              "inline-flex items-center gap-1 text-sm font-[family-name:var(--font-inter)] font-medium group-hover:gap-2 transition-all",
              service.featured ? "text-cyan" : accentColors[service.accent].text,
            ]}
          >
            Ver mas
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>

    <!-- Mobile Horizontal Cards -->
    <div class="lg:hidden flex flex-col gap-4">
      {services.map((service) => (
        <div
          class:list={[
            "reveal rounded-2xl p-5 flex items-start gap-4",
            service.featured
              ? "bg-navy text-white"
              : "bg-gray-50 border border-gray-100",
          ]}
        >
          <div
            class:list={[
              "w-13 h-13 rounded-xl flex items-center justify-center shrink-0",
              service.featured
                ? "bg-white/10"
                : accentColors[service.accent].iconBg,
            ]}
          >
            <span
              class:list={[
                service.featured ? "text-cyan" : accentColors[service.accent].text,
              ]}
              set:html={icons[service.icon]}
            />
          </div>
          <div class="flex-1 min-w-0">
            <h3
              class:list={[
                "text-base font-semibold font-[family-name:var(--font-inter)] mb-0.5",
                service.featured ? "text-white" : "text-navy",
              ]}
            >
              {service.title}
            </h3>
            <p
              class:list={[
                "text-xs mb-2",
                service.featured ? "text-cyan/80" : "text-gray-400",
              ]}
            >
              {service.subtitle}
            </p>
            <p
              class:list={[
                "text-sm leading-relaxed",
                service.featured ? "text-white/70" : "text-gray-500",
              ]}
            >
              {service.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
