---
const modules = [
  {
    title: "Booking",
    description: "Reserva de espacios de carga en linea con confirmacion inmediata.",
    icon: "package",
    color: "blue",
  },
  {
    title: "Documentacion",
    description: "Gestion digital de BL, facturas y documentos de exportacion.",
    icon: "file-text",
    color: "red",
  },
  {
    title: "Tracking",
    description: "Seguimiento en tiempo real de tu carga en cualquier punto del mundo.",
    icon: "map-pin",
    color: "cyan",
  },
  {
    title: "Analytics",
    description: "Dashboards con metricas de rendimiento y costos de operacion.",
    icon: "trending-up",
    color: "green",
  },
  {
    title: "Itinerarios",
    description: "Consulta de rutas, tiempos de transito y frecuencias de zarpe.",
    icon: "calendar",
    color: "amber",
  },
  {
    title: "Compliance",
    description: "Cumplimiento normativo y regulatorio automatizado.",
    icon: "shield-check",
    color: "purple",
  },
];

const iconSvgs: Record<string, string> = {
  "package": '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.29 7 12 12 20.71 7"/><line x1="12" y1="22" x2="12" y2="12"/></svg>',
  "file-text": '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>',
  "map-pin": '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>',
  "trending-up": '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>',
  "calendar": '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
  "shield-check": '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>',
};

const colorMap: Record<string, { icon: string; bg: string }> = {
  blue: { icon: "text-blue", bg: "bg-blue/10" },
  red: { icon: "text-red", bg: "bg-red/10" },
  cyan: { icon: "text-cyan", bg: "bg-cyan/10" },
  green: { icon: "text-green-400", bg: "bg-green-400/10" },
  amber: { icon: "text-amber-400", bg: "bg-amber-400/10" },
  purple: { icon: "text-purple-400", bg: "bg-purple-400/10" },
};
---

<section id="opb360" class="py-20 lg:py-28 bg-gradient-to-b from-navy to-navy-dark relative overflow-hidden">
  <!-- Decorative glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-blue/10 rounded-full blur-[150px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-14 lg:mb-20">
      <div class="reveal inline-flex items-center gap-2 px-4 py-2 rounded-full border border-red/30 bg-red/5 mb-6">
        <span class="w-2 h-2 bg-red rounded-full"></span>
        <span class="text-sm text-red font-[family-name:var(--font-inter)] font-medium">Plataforma Digital</span>
      </div>
      <h2 class="reveal text-[42px] lg:text-[56px] font-bold text-white font-[family-name:var(--font-inter)] leading-tight mb-4">
        OPB 360&deg;
      </h2>
      <p class="reveal text-lg lg:text-xl text-cyan font-[family-name:var(--font-inter)] font-medium mb-4">
        Impulsando el crecimiento, guiando el futuro
      </p>
      <p class="reveal text-base text-white/60 font-[family-name:var(--font-poppins)] max-w-2xl mx-auto">
        Una plataforma integral que centraliza todas tus operaciones logisticas en un solo lugar.
        Desde la reserva hasta la entrega, con visibilidad total.
      </p>
    </div>

    <!-- Module Grid -->
    <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-5 mb-14">
      {modules.map((mod) => (
        <div class="reveal group backdrop-blur-xl bg-white/[0.03] border border-white/[0.08] rounded-2xl p-5 lg:p-6 hover:bg-white/[0.06] hover:border-white/15 transition-all duration-300">
          <div class:list={["w-11 h-11 rounded-xl flex items-center justify-center mb-4", colorMap[mod.color].bg]}>
            <span class={colorMap[mod.color].icon} set:html={iconSvgs[mod.icon]} />
          </div>
          <h3 class="text-base lg:text-lg font-semibold text-white font-[family-name:var(--font-inter)] mb-2">
            {mod.title}
          </h3>
          <p class="text-sm text-white/50 font-[family-name:var(--font-poppins)] leading-relaxed">
            {mod.description}
          </p>
        </div>
      ))}
    </div>

    <!-- CTAs -->
    <div class="reveal flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://prod.opb.cl/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-red text-white rounded-xl font-[family-name:var(--font-inter)] font-semibold text-base hover:bg-red/90 transition-all shadow-lg shadow-red/25 hover:shadow-red/40"
      >
        Acceder a OPB 360&deg;
      </a>
      <a
        href="#contacto"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/5 backdrop-blur-sm border border-white/15 text-white rounded-xl font-[family-name:var(--font-inter)] font-semibold text-base hover:bg-white/10 transition-all"
      >
        Solicitar Demo
      </a>
    </div>
  </div>
</section>
