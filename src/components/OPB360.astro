---
const phases = [
  {
    number: "01",
    title: "Planificacion Estrategica",
    description: "Transforma el seguimiento de tus reservas en una ventaja competitiva, construyendo una base solida para la operacion y la documentacion.",
    accent: "cyan",
    modules: [
      {
        name: "Itinerarios",
        desc: "Integracion directa con la planificacion naviera de los traficos mas utilizados.",
        icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>',
      },
      {
        name: "Reservas",
        desc: "Visualizacion de naves, viajes, puertos y fechas criticas. Gestion centralizada de todos los bookings.",
        icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16.5 9.4 7.55 4.24"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.29 7 12 12 20.71 7"/><line x1="12" y1="22" x2="12" y2="12"/></svg>',
      },
    ],
  },
  {
    number: "02",
    title: "Ejecucion Fisica y Documental",
    description: "Donde el movimiento fisico del contenedor se sincroniza con el flujo de la documentacion aduanera.",
    accent: "blue",
    modules: [
      {
        name: "Control Documental",
        desc: "Control centralizado de B/L, Certificados Fitosanitarios, envios y legalizaciones. Visibilidad DUS en tiempo real.",
        icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>',
      },
      {
        name: "Transporte",
        desc: "Mapeo fisico customizable con 6 checkpoints: desde deposito hasta salida de puerto con notificaciones automaticas.",
        icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>',
      },
    ],
  },
  {
    number: "03",
    title: "Cierre Financiero",
    description: "La operacion impecable se traduce en finanzas transparentes. Desde el costo mas pequeno hasta la facturacion final, sin intervencion manual.",
    accent: "red",
    modules: [
      {
        name: "Ordenes de Servicio",
        desc: "Mas de 70 tipos de servicios detallados. Sincronizacion cloud con sistemas ERP.",
        icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="m9 14 2 2 4-4"/></svg>',
      },
      {
        name: "Liquidaciones",
        desc: "Liquidaciones por nave post zarpe. Transparencia total en cargos y respaldos para auditoria interna.",
        icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>',
      },
    ],
  },
];

const accentMap: Record<string, { text: string; bg: string; border: string; glow: string; line: string }> = {
  cyan: { text: "text-cyan", bg: "bg-cyan/10", border: "border-cyan/20", glow: "bg-cyan/20", line: "from-cyan/60 to-cyan/0" },
  blue: { text: "text-blue", bg: "bg-blue/10", border: "border-blue/20", glow: "bg-blue/20", line: "from-blue/60 to-blue/0" },
  red: { text: "text-red", bg: "bg-red/10", border: "border-red/20", glow: "bg-red/20", line: "from-red/60 to-red/0" },
};
---

<section id="opb360" class="py-20 lg:py-32 bg-gradient-to-b from-navy to-navy-dark relative overflow-hidden">
  <!-- Decorative -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-blue/8 rounded-full blur-[150px] pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-cyan/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-16 lg:mb-20">
      <div class="reveal inline-flex items-center gap-2 px-4 py-2 rounded-full border border-red/30 bg-red/5 mb-6">
        <span class="w-2 h-2 bg-red rounded-full"></span>
        <span class="text-sm text-red font-[family-name:var(--font-inter)] font-medium">Ecosistema Digital</span>
      </div>
      <h2 class="reveal text-[32px] lg:text-[52px] font-bold text-white font-[family-name:var(--font-inter)] leading-tight mb-4">
        Ecosistema OPB 360&deg;
      </h2>
      <p class="reveal text-lg lg:text-xl text-cyan font-[family-name:var(--font-inter)] font-medium mb-4">
        Gestion Logistica End-to-End para Cargas
      </p>
      <p class="reveal text-base text-white/50 font-[family-name:var(--font-poppins)] max-w-2xl mx-auto">
        Conectando el agenciamiento, el transporte y el control de datos en una plataforma integral que cubre las 3 fases de la operacion logistica.
      </p>
    </div>

    <!-- Phases -->
    <div class="space-y-6 lg:space-y-8 mb-16">
      {phases.map((phase) => (
        <div class="reveal backdrop-blur-xl bg-white/[0.03] border border-white/[0.08] rounded-2xl lg:rounded-3xl p-6 lg:p-8 hover:bg-white/[0.05] transition-all duration-300">
          <div class="grid lg:grid-cols-[280px_1fr] gap-6 lg:gap-10">
            {/* Phase header */}
            <div class="flex flex-col">
              <div class="flex items-center gap-3 mb-3">
                <span class:list={["text-sm font-mono font-bold tracking-wider", accentMap[phase.accent].text]}>
                  FASE {phase.number}
                </span>
                <div class:list={["h-px flex-1", `bg-gradient-to-r ${accentMap[phase.accent].line}`]}></div>
              </div>
              <h3 class="text-xl lg:text-2xl font-bold text-white font-[family-name:var(--font-inter)] mb-3">
                {phase.title}
              </h3>
              <p class="text-sm text-white/50 font-[family-name:var(--font-poppins)] leading-relaxed">
                {phase.description}
              </p>
            </div>

            {/* Modules */}
            <div class="grid sm:grid-cols-2 gap-4">
              {phase.modules.map((mod) => (
                <div class:list={["rounded-xl border p-5 transition-all duration-300 hover:scale-[1.02]", accentMap[phase.accent].border, "bg-white/[0.03]"]}>
                  <div class="flex items-center gap-3 mb-3">
                    <div class:list={["w-9 h-9 rounded-lg flex items-center justify-center", accentMap[phase.accent].bg]}>
                      <span class={accentMap[phase.accent].text} set:html={mod.icon} />
                    </div>
                    <h4 class="text-base font-semibold text-white font-[family-name:var(--font-inter)]">
                      {mod.name}
                    </h4>
                  </div>
                  <p class="text-sm text-white/45 font-[family-name:var(--font-poppins)] leading-relaxed">
                    {mod.desc}
                  </p>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Torre de Control callout -->
    <div class="reveal backdrop-blur-xl bg-gradient-to-r from-white/[0.05] to-white/[0.02] border border-cyan/15 rounded-2xl p-6 lg:p-8 mb-14">
      <div class="flex flex-col lg:flex-row items-start lg:items-center gap-6">
        <div class="w-14 h-14 rounded-2xl bg-cyan/10 flex items-center justify-center shrink-0">
          <svg class="w-7 h-7 text-cyan" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
        </div>
        <div class="flex-1">
          <h3 class="text-lg font-bold text-white font-[family-name:var(--font-inter)] mb-1">
            Torre de Control Logistica
          </h3>
          <p class="text-sm text-white/50 font-[family-name:var(--font-poppins)]">
            Dashboards avanzados en Power BI con estado en tiempo real, filtros estrategicos por cliente, nave, puerto o DUS, y alertas automatizadas para detectar atrasos en hitos criticos al instante.
          </p>
        </div>
        <a
          href="https://prod.opb.cl/"
          target="_blank"
          rel="noopener noreferrer"
          class="shrink-0 inline-flex items-center gap-2 px-6 py-3 bg-cyan/10 border border-cyan/20 text-cyan rounded-xl font-[family-name:var(--font-inter)] font-medium text-sm hover:bg-cyan/20 transition-all"
        >
          Ver Plataforma
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
        </a>
      </div>
    </div>

    <!-- CTAs -->
    <div class="reveal flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://prod.opb.cl/"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-red text-white rounded-xl font-[family-name:var(--font-inter)] font-semibold text-base hover:bg-red/90 transition-all shadow-lg shadow-red/25 hover:shadow-red/40"
      >
        Acceder a OPB 360&deg;
      </a>
      <a
        href="#contacto"
        class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/5 backdrop-blur-sm border border-white/15 text-white rounded-xl font-[family-name:var(--font-inter)] font-semibold text-base hover:bg-white/10 transition-all"
      >
        Solicitar Demo
      </a>
    </div>
  </div>
</section>
