---
const stats = [
  { value: "+15", label: "Años experiencia" },
  { value: "24/7", label: "Atención" },
  { value: "+50", label: "Navieras" },
  { value: "3", label: "Oficinas" },
];
---

<section id="inicio" class="relative min-h-screen flex flex-col justify-center overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0">
    <img
      src="https://images.unsplash.com/photo-1594110336951-5bc8c12d6b27?w=1920&q=80"
      alt="Puerto maritimo con contenedores"
      class="w-full h-full object-cover"
      loading="eager"
    />
    <!-- Dark gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-navy via-navy/80 to-navy/40"></div>
    <!-- Extra bottom fade -->
    <div class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-navy to-transparent"></div>
  </div>

  <!-- Decorative mesh glows -->
  <div class="absolute top-1/4 -left-32 w-96 h-96 bg-blue/20 rounded-full blur-[128px] pointer-events-none"></div>
  <div class="absolute bottom-1/3 -right-32 w-80 h-80 bg-cyan/15 rounded-full blur-[100px] pointer-events-none"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-red/8 rounded-full blur-[150px] pointer-events-none"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-32 pb-16 lg:pt-40 lg:pb-24">
    <div class="grid lg:grid-cols-[1fr_380px] gap-12 items-center">
      <!-- Left Content -->
      <div class="max-w-2xl">
        <!-- Badge -->
        <div class="reveal inline-flex items-center gap-2 px-4 py-2 rounded-full border border-cyan/30 bg-cyan/5 mb-8">
          <span class="w-2 h-2 bg-cyan rounded-full animate-pulse"></span>
          <span class="text-sm text-cyan font-[family-name:var(--font-inter)] font-medium">
            Temporada 2025-2026 &middot; Reservas abiertas
          </span>
        </div>

        <!-- Title -->
        <h1 class="reveal text-[38px] lg:text-[64px] leading-[1.05] font-bold text-white font-[family-name:var(--font-inter)] mb-6">
          Conectamos Chile<br />con el mundo
        </h1>

        <!-- Gradient accent line -->
        <div class="reveal w-15 h-1 bg-gradient-to-r from-red to-cyan rounded-full mb-6"></div>

        <!-- Subtitle -->
        <p class="reveal text-xl lg:text-[28px] text-cyan font-[family-name:var(--font-inter)] font-medium mb-4">
          Logistica naviera de clase mundial
        </p>

        <!-- Description -->
        <p class="reveal text-base lg:text-[17px] text-white/70 font-[family-name:var(--font-poppins)] leading-relaxed mb-10 max-w-xl">
          Exportacion e importacion de cargas refrigeradas, congeladas y especializadas.
          Mas de 15 anos de experiencia con alianzas en las principales navieras del planeta.
        </p>

        <!-- CTAs -->
        <div class="reveal flex flex-col sm:flex-row gap-4">
          <a
            href="#contacto"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-red text-white rounded-xl font-[family-name:var(--font-inter)] font-semibold text-base hover:bg-red/90 transition-all shadow-lg shadow-red/25 hover:shadow-red/40"
          >
            Cotizar Ahora
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a
            href="#servicios"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/5 backdrop-blur-sm border border-white/15 text-white rounded-xl font-[family-name:var(--font-inter)] font-semibold text-base hover:bg-white/10 transition-all"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Ver Como Trabajamos
          </a>
        </div>
      </div>

      <!-- Right Column: Float Cards (Desktop only) -->
      <div class="hidden lg:flex flex-col gap-4">
        <!-- Float Card: Tracking Activo -->
        <div class="reveal backdrop-blur-xl bg-white/5 border border-white/10 rounded-2xl p-6 shadow-2xl">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-cyan/10 flex items-center justify-center">
              <svg class="w-5 h-5 text-cyan" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p class="text-white text-sm font-[family-name:var(--font-inter)] font-semibold">Tracking Activo</p>
              <p class="text-white/50 text-xs">En tiempo real</p>
            </div>
            <span class="ml-auto w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
          </div>
          <div class="space-y-3">
            <div class="flex items-center justify-between text-sm">
              <span class="text-white/60">Chile</span>
              <span class="text-white/40">&#8594;</span>
              <span class="text-white/60">Asia Pacific</span>
            </div>
            <div class="w-full h-2 bg-white/10 rounded-full overflow-hidden">
              <div class="h-full w-2/3 bg-gradient-to-r from-blue to-cyan rounded-full"></div>
            </div>
            <div class="flex items-center justify-between text-xs text-white/40">
              <span>Valparaiso</span>
              <span>67% completado</span>
              <span>Shanghai</span>
            </div>
          </div>
        </div>

        <!-- Mini Tracking Card -->
        <div class="reveal backdrop-blur-xl bg-white/5 border border-white/10 rounded-2xl p-5 shadow-2xl">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-lg bg-red/10 flex items-center justify-center">
              <svg class="w-4 h-4 text-red" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="2"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            </div>
            <div class="flex-1">
              <p class="text-white text-sm font-[family-name:var(--font-inter)] font-medium">Carga Terrestre</p>
              <p class="text-white/40 text-xs">Santiago &rarr; Valparaiso</p>
            </div>
            <span class="text-xs text-cyan font-[family-name:var(--font-inter)] font-medium px-2 py-1 rounded-md bg-cyan/10">En ruta</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Glass Stats Bar -->
  <div class="relative z-10 w-full mt-auto">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-8">
      <div class="reveal grid grid-cols-2 lg:grid-cols-4 gap-3 lg:gap-4">
        {stats.map((stat) => (
          <div class="backdrop-blur-xl bg-white/5 border border-white/[0.13] rounded-2xl p-5 lg:p-6 text-center">
            <p class="text-2xl lg:text-3xl font-bold text-white font-[family-name:var(--font-inter)]">
              {stat.value}
            </p>
            <p class="text-sm text-white/60 font-[family-name:var(--font-poppins)] mt-1">
              {stat.label}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
